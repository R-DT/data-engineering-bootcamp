# Environment Profile Setup
ENVIRONMENT=DEVELOPMENT

# Pipeline Engineering Parameters
NUMBER_OF_TRANSACTIONS=1000
RANDOM_SEED=42

# Local Storage Target Absolute Directory Bindings
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
REPORTS_DIR=data/reports

# PostgreSQL Database Credentials
# PostgreSQL Warehouse Target Profiles
DB_USER=postgres
DB_PASS=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fintech_db

